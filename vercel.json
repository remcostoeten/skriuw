{
  "buildCommand": "pnpm -r --filter '@skriuw/db' build && cd apps/web && pnpm build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "pnpm install",
  "framework": null,
  "devCommand": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_STORAGE_ADAPTER": "serverless-api"
  }
}
