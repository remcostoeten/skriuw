{
  "buildCommand": "pnpm -r --filter '@skriuw/db' build && cd next-app && pnpm build",
  "outputDirectory": "dist/spa",
  "installCommand": "corepack enable && pnpm install",
  "framework": null,
  "devCommand": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_STORAGE_ADAPTER": "serverless-api"
  }
}
