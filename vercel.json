{
  "buildCommand": "cd apps/web && pnpm build",
  "outputDirectory": "dist/spa",
  "devCommand": "cd apps/web && pnpm dev",
  "installCommand": "pnpm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "apps/api/**/*.ts": {
      "runtime": "@vercel/node"
    }
  },
  "env": {
    "VITE_STORAGE_ADAPTER": "serverless-api"
  }
}
