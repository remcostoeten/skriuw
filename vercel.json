{
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "framework": "nextjs",
  "outputDirectory": "apps/web/.next",
  "devCommand": "bun run dev",
  "functions": {
    "apps/web/**/*.ts": {
      "maxDuration": 30
    },
    "apps/web/**/*.tsx": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
