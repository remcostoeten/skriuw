# Storage Configuration
# Available options: localStorage, instantdb, drizzle-turso, pglite
VITE_STORAGE_ADAPTER=localhost

# InstantDB Configuration (when using instantdb adapter)
# VITE_INSTANTDB_APP_ID=your_app_id_here

# Drizzle + Turso Configuration (when using drizzle-turso adapter)
# VITE_TURSO_URL=libsql://your-db-name.turso.io
# VITE_TURSO_AUTH_TOKEN=your_auth_token_here

# PGLite Configuration (when using pglite adapter)
# Additional PGLite-specific options can be added here