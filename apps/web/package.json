{
	"name": "web",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"build": "bun --env-file=../../.env.local --bun next build",
		"validate-env": "tsx -e \"import('../../packages/env/src/server.ts').catch((err) => { console.error(err); process.exit(1); })\"",
		"dev": "bun --env-file=../../.env.local --bun next dev",
		"lint": "next lint --dir .",
		"check-types": "tsc --noEmit",
		"start": "bun --env-file=../../.env.local --bun next start",
		"test": "bun test --preload ./test-setup.ts",
		"test:verbose": "bun test --preload ./test-setup.ts --verbose",
		"tauri:dev": "bunx --bun tauri dev",
		"tauri:build": "TAURI_BUILD=true bunx --bun tauri build",
		"tauri:build:mac": "TAURI_BUILD=true bunx --bun tauri build --target universal-apple-darwin",
		"tauri:build:deb": "TAURI_BUILD=true bunx --bun tauri build -b deb",
		"seed:identity-guide": "bun scripts/seed-identity-guide.ts",
		"seed:identity-guide:stats": "bun scripts/seed-identity-guide.ts stats",
		"seed:sync": "bun scripts/sync-seeds.ts"
	},
	"dependencies": {
		"@blocknote/core": "^0.44.2",
