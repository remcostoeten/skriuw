{
	"extends": "@skriuw/config/typescript/nextjs",
	"compilerOptions": {
		"baseUrl": ".",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"target": "es2022",
		"lib": ["dom", "dom.iterable", "es2022", "es2015", "es2017", "es2015.promise", "webworker"],
		"types": ["node"],
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./*"],
			"@skriuw/ui": ["../../packages/ui"],
			"@skriuw/crud": ["../../packages/crud"],
			"@skriuw/db": ["../../packages/db"],
			"@skriuw/shared": ["../../packages/shared"],
			"@skriuw/config": ["../../packages/config"],
			"@skriuw/env": ["../../packages/env"],
			"@skriuw/storage": ["./lib/storage"],
			"@skriuw/storage/*": ["./lib/storage/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"app/(auth)/d"
	],
	"exclude": [
		"node_modules",
		"drizzle.config.ts",
		"**/*.test.ts",
		"**/*.test.tsx",
		"test-setup.ts",
		"src-tauri"
	]
}
