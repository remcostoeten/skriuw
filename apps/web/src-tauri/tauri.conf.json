{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Skriuw",
  "version": "0.0.1",
  "identifier": "app.skriuw.skriuw",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:42069",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Skriuw",

        "width": 1000,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 900,
        "resizable": true,
        "decorations":false,
        "transparent":true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
