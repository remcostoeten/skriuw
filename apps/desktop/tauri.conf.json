{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "skriuw",
  "version": "0.1.0",
  "identifier": "com.skriuw.app",
  "build": {
    "frontendDist": "../../dist/spa",
    "devUrl": "http://localhost:42069",
    "beforeDevCommand": "cd ../web && pnpm dev",
    "beforeBuildCommand": "cd ../web && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Skriuw",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
