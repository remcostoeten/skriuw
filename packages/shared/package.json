{
	"name": "@skriuw/shared",
	"version": "0.1.0",
	"description": "Shared utilities, hooks, and components for the Skriuw monorepo",
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.mjs",
			"require": "./dist/client.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit"
	},
	"peerDependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0"
	},
	"devDependencies": {
		"@skriuw/config": "workspace:*",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"tsup": "latest",
		"typescript": "latest"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"tailwind-merge": "^2.5.4",
		"tailwindcss-animate": "^1.0.7"
	}
}