{
	"name": "@skriuw/env",
	"version": "0.0.0",
	"private": true,
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.mjs",
			"require": "./dist/client.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"import": "./dist/server.mjs",
			"require": "./dist/server.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "eslint . --max-warnings 0",
		"check-types": "tsc --noEmit",
		"validate": "tsx src/validate-build.ts",
		"check-env-usage": "tsx src/validate-build.ts --check-env-usage"
	},
	"dependencies": {
		"dotenv": "^17.2.3",
		"picocolors": "^1.1.1",
		"zod": "^3.24.0",
		"@skriuw/config": "workspace:*",
		"@types/glob": "^8.1.0",
		"@types/node": "^22.0.0",
		"glob": "^10.4.5",
		"tsup": "^8.0.0",
		"typescript": "^5.9.3"
	},
	"devDependencies": {}
}