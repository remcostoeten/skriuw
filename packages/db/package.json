{
	"name": "@skriuw/db",
	"version": "0.0.0",
	"private": true,
	"main": "./index.ts",
	"types": "./index.ts",
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "eslint . --max-warnings 0",
		"check-types": "tsc --noEmit",
		"db:push": "bun --env-file=../../.env.local drizzle-kit push",
		"db:generate": "bun --env-file=../../.env.local drizzle-kit generate",
		"db:studio": "bun --env-file=../../.env.local drizzle-kit studio"
	},
	"dependencies": {
		"@neondatabase/serverless": "^0.10.0",
		"drizzle-orm": "catalog:",
		"postgres": "catalog:"
	},
	"devDependencies": {
		"@skriuw/config": "workspace:*",
		"dotenv": "^17.2.3",
		"drizzle-kit": "catalog:",
		"tsup": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}