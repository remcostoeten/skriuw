{
  "name": "@skriuw/db",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "seed": "pnpm build && node seed.js",
    "seed:force": "pnpm build && node seed.js --force",
    "seed:clear": "pnpm build && node seed.js --clear",
    "reset": "tsx reset-schema.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "postgres": "^3.4.7",
    "@neondatabase/serverless": "^0.10.0"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "typescript": "^5.9.2",
    "drizzle-kit": "^0.31.7",
    "dotenv": "^16.4.5"
  }
}

