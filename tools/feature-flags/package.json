{
  "name": "@skriuw/feature-flags",
  "version": "0.1.0",
  "description": "Extensible feature flag engine with pluggable storage and React/Next.js bindings.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "require": "./dist/core/index.cjs",
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./react": {
      "require": "./dist/react/index.cjs",
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./next": {
      "require": "./dist/next/index.cjs",
      "import": "./dist/next/index.js",
      "types": "./dist/next/index.d.ts"
    },
    "./adapters/drizzle": {
      "require": "./dist/adapters/drizzle/index.cjs",
      "import": "./dist/adapters/drizzle/index.js",
      "types": "./dist/adapters/drizzle/index.d.ts"
    },
    "./adapters/local-storage": {
      "require": "./dist/adapters/local-storage/index.cjs",
      "import": "./dist/adapters/local-storage/index.js",
      "types": "./dist/adapters/local-storage/index.d.ts"
    },
    "./adapters/indexeddb": {
      "require": "./dist/adapters/indexeddb/index.cjs",
      "import": "./dist/adapters/indexeddb/index.js",
      "types": "./dist/adapters/indexeddb/index.d.ts"
    },
    "./adapters/instantdb": {
      "require": "./dist/adapters/instantdb/index.cjs",
      "import": "./dist/adapters/instantdb/index.js",
      "types": "./dist/adapters/instantdb/index.d.ts"
    },
    "./adapters/memory": {
      "require": "./dist/adapters/memory/index.cjs",
      "import": "./dist/adapters/memory/index.js",
      "types": "./dist/adapters/memory/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "examples"],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["feature", "flags", "react", "nextjs", "drizzle", "typescript"],
  "author": "Skriuw",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0",
    "clsx": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "drizzle-orm": "^0.31.3",
    "drizzle-kit": "^0.23.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
