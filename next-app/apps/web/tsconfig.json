{
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@skriuw/storage": [
        "./lib/storage/index.ts"
      ],
      "@skriuw/storage/*": [
        "./lib/storage/*"
      ],
      "@skriuw/db": [
        "./lib/db/index.ts"
      ],
      "@quantum-work/ui": [
        "../../packages/ui"
      ],
      "@quantum-work/core-logic": [
        "../../packages/core-logic"
      ],
      "@quantum-work/db": [
        "../../packages/db"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "drizzle.config.ts"
  ]
}
