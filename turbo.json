{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"globalEnv": ["NODE_ENV", "DATABASE_PROVIDER"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"],
			"env": ["NEXT_PUBLIC_.*"]
		},
		"build:cli": {
			"cache": false,
			"outputs": ["bin/**"]
		},
		"lint": {
			"dependsOn": ["^lint"],
			"outputs": []
		},
		"check-types": {
			"dependsOn": ["^check-types"],
			"outputs": []
		},
		"test": {
			"dependsOn": ["^build"],
			"cache": false,
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"clean": {
			"cache": false,
			"outputs": []
		}
	}
}
