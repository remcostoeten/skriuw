# =============================================================================
# SKRIUW - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the required values
# Never commit your .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# CORE APPLICATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT="3000"
DEBUG="false"

# -----------------------------------------------------------------------------
# SUPABASE (Required - Core auth & persistence)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"

# -----------------------------------------------------------------------------
# BETTER AUTH (If migrating from Better Auth - currently using Supabase Auth)
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET="your-better-auth-secret"
BETTER_AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# -----------------------------------------------------------------------------
# DATABASE (If using direct DB access alongside Supabase)
# -----------------------------------------------------------------------------
DATABASE_PROVIDER="neon"
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# -----------------------------------------------------------------------------
# ENCRYPTION KEYS
# -----------------------------------------------------------------------------
AI_PROMPT_ENCRYPTION_KEY="your-64-char-hex-key"
CONNECTOR_ENCRYPTION_KEY="your-32-char-hex-key"

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS - GITHUB (Configure in Supabase dashboard)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS - GOOGLE (Configure in Supabase dashboard)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_DRIVE_CLIENT_SECRET="your-google-drive-client-secret"

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS - DROPBOX (Configure in Supabase dashboard)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DROPBOX_CLIENT_ID="your-dropbox-client-id"
DROPBOX_CLIENT_SECRET="your-dropbox-client-secret"

# -----------------------------------------------------------------------------
# AI PROVIDERS (For AI-powered features)
# -----------------------------------------------------------------------------
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_BACKUP_KEY="your-backup-gemini-api-key"
GROK_API_KEY="your-grok-api-key"

# -----------------------------------------------------------------------------
# STORAGE - UPLOADTHING
# -----------------------------------------------------------------------------
UPLOADTHING_TOKEN="your-uploadthing-token"

# -----------------------------------------------------------------------------
# VERCEL & CRON
# -----------------------------------------------------------------------------
CRON_SECRET="your-cron-secret"
VERCEL_OIDC_TOKEN="your-vercel-oidc-token"

# -----------------------------------------------------------------------------
# LOGGING CONTROLS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_AUTH_LOGGING="false"
NEXT_PUBLIC_ENABLE_GENERAL_LOGGING="false"
NEXT_PUBLIC_ENABLE_SHORTCUT_LOGGING="false"
NEXT_PUBLIC_DISABLE_AUTO_SIGNIN="false"
