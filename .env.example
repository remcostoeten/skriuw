# =============================================================================
# SKRIUW - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the required values
# Never commit your .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (Required - Core auth & persistence)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-legacy-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-server-only-service-role-key"

# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"
AI_KEYS_ENCRYPTION_SECRET="your-ai-provider-key-encryption-secret"

# -----------------------------------------------------------------------------
# MOBILE (Expo / React Native)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
EXPO_PUBLIC_SUPABASE_ANON_KEY="your-legacy-supabase-anon-key"