# =============================================================================
# Skriuw Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All variables are validated at startup - you'll get helpful errors if missing.

# =============================================================================
# DATABASE (Required)
# =============================================================================

# PostgreSQL connection string
# Neon: postgresql://user:password@host.neon.tech/database?sslmode=require
# Local: postgresql://user:password@localhost:5432/database
DATABASE_URL=postgresql://user:password@localhost:5432/skriuw

# Database provider (auto-detected if not set)
# Options: neon | postgres
DATABASE_PROVIDER=postgres

# =============================================================================
# AUTHENTICATION (Optional - Better Auth)
# =============================================================================

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Better Auth config
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# AI / LLM (Optional)
# =============================================================================

# Google Gemini
GEMINI_API_KEY=
GEMINI_BACKUP_KEY=

# =============================================================================
# CLIENT-SIDE (NEXT_PUBLIC_*)
# =============================================================================

# App URL (auto-detected on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Don't force auto session on page load (dev debug)
NEXT_PUBLIC_DISABLE_AUTO_SIGNIN=true

# Add additional debug logging for session
NEXT_PUBLIC_DEBUG_SESSION=true

# =============================================================================
# CRON JOBS
# =============================================================================

# Secret for securing cron job endpoints
CRON_SECRET=generate-a-strong-random-secret-here

