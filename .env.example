```
# ==============================================================================
#  SKRIUW ENVIRONMENT CONFIGURATION
# ==============================================================================
#  Copy this file to .env and fill in the values.
#  Do NOT commit your real .env file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# CORE & DATABASE (Required)
# ------------------------------------------------------------------------------

# PostgreSQL Connection String (Transaction Pooling)
# Example: postgresql://user:password@host:port/database
# For Neon: postgresql://user:password@ep-xyz.region.aws.neon.tech/neondb
DATABASE_URL=""

# Database Provider ('neon' or 'postgres')
# Default: postgres
DATABASE_PROVIDER="postgres"

# ------------------------------------------------------------------------------
# AUTHENTICATION
# ------------------------------------------------------------------------------

# Better Auth Secret (Required for Auth)
# Generate a strong random string (min 32 chars)
# Command to generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Base URL for Auth (e.g. http://localhost:3000)
BETTER_AUTH_URL="http://localhost:3000"

# Trust Host (Set to 'true' if running behind a proxy or in container)
AUTH_TRUST_HOST="false"

# ------------------------------------------------------------------------------
# OAUTH PROVIDERS (Optional)
# ------------------------------------------------------------------------------

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ------------------------------------------------------------------------------
# AI & ENCRYPTION
# ------------------------------------------------------------------------------

# Google Gemini API Keys (For AI Features)
GEMINI_API_KEY=""
GEMINI_BACKUP_KEY=""

# Connector Encryption Key (Required for Backup Connectors)
# Critical: Used to encrypt/decrypt sensitive tokens in the database.
# If lost, encrypted data cannot be recovered.
# Command to generate: openssl rand -hex 16
CONNECTOR_ENCRYPTION_KEY=""

# Cron Secret (Required for Scheduled Tasks)
# Protects the /api/cron/cleanup endpoint.
# Command to generate: openssl rand -hex 32
CRON_SECRET=""

# ------------------------------------------------------------------------------
# CLOUD STORAGE BACKUP (Optional)
# ------------------------------------------------------------------------------

# Dropbox Integration
NEXT_PUBLIC_DROPBOX_CLIENT_ID=""
DROPBOX_CLIENT_SECRET=""

# Google Drive Integration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_DRIVE_CLIENT_SECRET=""

# ------------------------------------------------------------------------------
# CLIENT-SIDE CONFIGURATION & FLAGS
# ------------------------------------------------------------------------------

# App URL (Public)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel Deployment URL (Automatically set by Vercel)
# NEXT_PUBLIC_VERCEL_URL=""

# Feature Flags & Logging
NEXT_PUBLIC_ENABLE_AUTH_LOGGING="false"
NEXT_PUBLIC_ENABLE_SHORTCUT_LOGGING="false"
NEXT_PUBLIC_ENABLE_GENERAL_LOGGING="false"
NEXT_PUBLIC_DISABLE_AUTO_SIGNIN="false"

# ------------------------------------------------------------------------------
# SERVER CONFIGURATION (Dev/Test)
# ------------------------------------------------------------------------------
NODE_ENV="development"
PORT="3000"
DEBUG="false"
