src-tauri/
**/src-tauri/
*.rs
Cargo.toml
Cargo.lock
target/
.tauri/
*.appimage
*.deb
*.dmg
*.exe

# Exclude local Next dev cache
apps/web/.next/dev
apps/web/.next/cache

# Exclude source maps (major size reduction)
**/*.map
*.map
apps/web/.next/**/*.map

# Turbo cache
.turbo
**/.turbo

# Exclude other apps (keep only web)
apps/desktop/
apps/cli/

# Exclude docs and test files
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/*.stories.tsx
**/coverage/
**/node_modules/.cache/

# Exclude lock files for other package managers
package-lock.json
pnpm-lock.yaml
