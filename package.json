{
  "name": "skriuw",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo for Skriuw - local-first note taking app",
  "workspaces": [
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "bun run --filter @skriuw/instantdb dev",
    "build": "bun run --filter @skriuw/instantdb build",
    "lint": "bun run --filter @skriuw/instantdb lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "packageManager": "bun@1.1.0"
}
