{
  "name": "skriuw-monorepo",
  "version": "0.1.0",
  "devDependencies": {
    "@skriuw/eslint-config": "workspace:*",
    "@skriuw/typescript-config": "workspace:*",
    "baseline-browser-mapping": "^2.9.5",
    "dotenv": "^17.2.3",
    "next": "16.0.2",
    "postgres": "^3.4.7",
    "prettier": "^3.6.2",
    "tinyglobby": "^0.2.15",
    "turbo": "^2.6.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.3",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "bun tools/check-db.ts && echo \"\\n🚀 Starting Skriuw...\\n📦 Database: ${DATABASE_PROVIDER:-postgres} (Check .env to switch)\\n\" && turbo dev",
    "start": "turbo start",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "db": "./bin/db-cli",
    "validate-env": "cd packages/env && bun run check-env-usage",
    "gen": "cd packages/db && bun drizzle-kit generate",
    "migrate": "cd packages/db && bun drizzle-kit migrate",
    "dbpush": "cd packages/db && bun drizzle-kit push",
    "studio": "cd packages/db && bun drizzle-kit studio",
    "validate": "turbo lint check-types test build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@blocknote/mantine": "^0.44.1",
    "@blocknote/xl-ai": "^0.44.0",
    "better-auth": "^1.4.5",
    "next-themes": "^0.4.6"
  }
}