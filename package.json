{
	"name": "skriuw-monorepo",
	"version": "0.1.0",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "cd apps/web && bun --bun run build",
		"build:packages": "cd packages/shared && bun run build && cd ../crud && bun run build && cd ../ui && bun run build",
		"dev": "cd apps/web && bun --bun run dev",
		"start": "cd apps/web && bun --bun run start",
		"lint": "bun run --cwd packages/style lint",
		"lint:fix": "bun run --cwd packages/style lint:fix",
		"format": "bun run --cwd packages/style format",
		"format:fix": "bun run --cwd packages/style format:fix",
		"fix": "bun run --cwd packages/style fix",
		"check-types": "turbo check-types",
		"test": "turbo test",
		"test:verbose": "turbo test:verbose --no-cache --continue",
		"gen": "cd packages/db && bun --env-file=../../.env.local drizzle-kit generate",
		"migrate": "cd packages/db && bun --env-file=../../.env.local drizzle-kit migrate",
		"dbpush": "cd packages/db && bun --env-file=../../.env.local drizzle-kit push",
		"studio": "cd packages/db && bun --env-file=../../.env.local drizzle-kit studio",
		"validate": "turbo lint check-types test build",
		"dev-cli": "bun scripts/dev-cli.ts",
		"sync-seeds": "cd packages/db && bun --env-file=../../.env.local scripts/sync-seeds.ts"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@vercel/analytics": "^1.6.1",
		"better-auth": "^1.4.5",
		"next-themes": "^0.4.6"
	},
	"devDependencies": {
		"@skriuw/config": "workspace:*",
		"baseline-browser-mapping": "^2.9.5",
		"dotenv": "^17.2.3",
		"next": "16.0.10",
		"postgres": "^3.4.7",
		"tinyglobby": "^0.2.15",
		"turbo": "^2.6.2",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.3"
}
