{
	"name": "skriuw-monorepo",
	"version": "0.1.0",
	"devDependencies": {
		"@skriuw/config": "workspace:*",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"baseline-browser-mapping": "^2.9.5",
		"dotenv": "^17.2.3",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-import": "^2.25.2",
		"eslint-plugin-jsx-a11y": "^6.8.0",
		"eslint-plugin-react": "^7.33.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"next": "16.0.10",
		"postgres": "^3.4.7",
		"prettier": "^3.6.2",
		"tinyglobby": "^0.2.15",
		"turbo": "^2.6.2",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.3",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "bun scripts/dev.ts",
		"start": "turbo start",
		"lint": "turbo lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\"",
		"check-types": "turbo check-types",
		"test": "turbo test",
		"gen": "cd packages/db && bun drizzle-kit generate",
		"migrate": "cd packages/db && bun drizzle-kit migrate",
		"dbpush": "cd packages/db && bun drizzle-kit push",
		"studio": "cd packages/db && bun drizzle-kit studio",
		"validate": "turbo lint check-types test build"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"better-auth": "^1.4.5",
		"next-themes": "^0.4.6",
		"three": "^0.182.0"
	}
}