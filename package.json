{
  "name": "@skriuw/monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd apps/web && pnpm dev",
    "dev:api": "vercel dev --listen 3000",
    "dev:all": "concurrently \"pnpm dev:api\" \"pnpm dev\" --names \"API,WEB\" --prefix-colors \"blue,green\"",
    "build": "pnpm -r --filter '@skriuw/*' build",
    "build:web": "cd apps/web && pnpm build",
    "build:db": "cd packages/db && pnpm build",
    "build:storage": "cd packages/storage && pnpm build",
    "tauri:dev": "cd apps/desktop && pnpm tauri:dev",
    "tauri:build": "cd apps/desktop && pnpm tauri:build",
    "test": "vitest --run",
    "lint": "pnpm -r --parallel lint",
    "lint:fix": "pnpm -r --parallel lint:fix",
    "format:fix": "prettier --write .",
    "typecheck": "pnpm -r --parallel typecheck",
    "db:push": "cd packages/db && pnpm db:push",
    "db:generate": "cd packages/db && pnpm db:generate",
    "db:studio": "cd packages/db && pnpm db:studio",
    "db:seed": "cd packages/db && pnpm seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.2.1",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.47.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.14.0+sha512.ad27a79641b49c3e481a16a805baa71817a04bbe06a38d17e60e2eaee83f6a146c6a688125f5792e48dd5ba30e7da52a5cda4c3992b9ccf333f9ce223af84748"
}
