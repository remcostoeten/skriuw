{
  "name": "skriuw-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "dev:web": "bun --filter web dev",
    "build": "bun run build:web",
    "build:web": "bun --filter web build",
    "start": "bun run start:web",
    "start:web": "bun --filter web start",
    "lint": "bun run lint:web",
    "lint:web": "bun --filter web lint",
    "lint:fix": "bun run lint:fix:web",
    "lint:fix:web": "bun --filter web lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "bun run typecheck:web",
    "typecheck:web": "bun --filter web typecheck",
    "db:push": "bun --filter @skriuw/db db:push",
    "db:generate": "bun --filter @skriuw/db db:generate",
    "db:studio": "bun --filter @skriuw/db db:studio"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.7",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "turbo": "^2.4.0"
  }
}
