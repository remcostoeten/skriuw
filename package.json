    "build:instantdb": "pnpm --filter instantdb-app build",
    "tauri:turso": "pnpm --filter turso-app tauri dev",
    "tauri:instantdb": "pnpm --filter instantdb-app tauri dev"
  },
  "keywords": ["tauri", "turso", "instantdb", "local-first", "drizzle"],
