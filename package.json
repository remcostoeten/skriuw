{
  "name": "skriuw-monorepo",
  "version": "0.1.0",
  "devDependencies": {
    "@skriuw/eslint-config": "workspace:*",
    "@skriuw/typescript-config": "workspace:*",
    "next": "16.0.2",
    "prettier": "^3.6.2",
    "turbo": "^2.6.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.3",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo check-types",
    "test": "turbo test"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "next-themes": "^0.4.6"
  }
}