{
  "name": "skriuw",
  "version": "0.0.1",
  "private": true,
  "description": "Monorepo for Skriuw - local-first note taking app",
  "workspaces": [
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "bun run --filter @skriuw/instantdb dev",
    "tauri": "bun run --filter @skriuw/instantdb tauri",
    "build": "bun run --filter @skriuw/instantdb build",
    "lint": "bun run --filter @skriuw/instantdb lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "seeder": "bun run --filter @skriuw/seeder dev",
    "seed": "bun run --filter @skriuw/seeder seed",
    "seed-cli": "bun run --filter @skriuw/seeder seed-cli",
    "seed-quick": "bun run --filter @skriuw/seeder seed-quick",
    "kill:dev": "bash scripts/kill-dev.sh"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "packageManager": "bun@1.1.0"
}
